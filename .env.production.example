# 复制为 .env.production，仅保存在服务器。不要提交真实值。
PDP_ENV=production
DJANGO_DEBUG=0
DJANGO_SECRET_KEY=replace-with-at-least-50-random-characters
DJANGO_ALLOWED_HOSTS=pdp.example.com
DJANGO_CSRF_TRUSTED_ORIGINS=https://pdp.example.com
PDP_FRONTEND_URL=https://pdp.example.com/
DJANGO_SECURE_SSL_REDIRECT=0

# 推荐填写同 VPC 的阿里云 RDS PostgreSQL 地址。
DATABASE_URL=postgresql://pdp_lab:replace-password@postgres:5432/pdp_lab
DB_CONN_MAX_AGE=60

# Redis 可先运行在 Compose；生产扩容时替换为阿里云 Redis 内网地址。
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
CELERY_WORKER_CONCURRENCY=2

PDP_DIAGNOSIS_ADAPTER=auto
PDP_AI_PROTOCOL=chat_completions
PDP_MODEL_NAME=mimo-v2.5
OPENAI_BASE_URL=
OPENAI_API_KEY=
OPENAI_TIMEOUT_SECONDS=180
PDP_ALLOW_MOCK_DIAGNOSIS=0

# 默认使用 Docker 持久卷；切换 OSS 时补齐下列配置。
PDP_MEDIA_STORAGE=filesystem
PDP_MEDIA_ROOT=/app/backend/media
# PDP_MEDIA_STORAGE=oss
# ALIYUN_OSS_ACCESS_KEY_ID=
# ALIYUN_OSS_ACCESS_KEY_SECRET=
# ALIYUN_OSS_ENDPOINT=https://oss-cn-hangzhou.aliyuncs.com
# ALIYUN_OSS_BUCKET_NAME=
# ALIYUN_OSS_CUSTOM_DOMAIN=
# ALIYUN_OSS_PRIVATE=1
# ALIYUN_OSS_URL_EXPIRE_SECONDS=3600

GUNICORN_WORKERS=3
GUNICORN_THREADS=2
GUNICORN_TIMEOUT=240
DJANGO_LOG_LEVEL=INFO

# 仅启用 Compose 自带 PostgreSQL（--profile local-infra）时需要。
POSTGRES_DB=pdp_lab
POSTGRES_USER=pdp_lab
POSTGRES_PASSWORD=replace-database-password

PDP_HTTP_PORT=80
PDP_HTTPS_PORT=443
# 域名证书放入 /srv/pdp-lab/shared/tls 后，同时改为 1。
PDP_ENABLE_TLS=0
