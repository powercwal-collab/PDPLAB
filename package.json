{
  "name": "pdp-lab-prototype",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:api": ".venv/bin/python backend/manage.py runserver 127.0.0.1:8000",
    "dev:worker": ".venv/bin/celery --workdir backend -A pdp_lab_backend worker --loglevel=info --pool=solo",
    "check:api": ".venv/bin/python backend/manage.py check && .venv/bin/python backend/manage.py test diagnosis",
    "build": "vite build && mkdir -p dist/server && cp server/index.js dist/server/index.js",
    "preview": "vite preview"
  },
  "dependencies": {
    "@phosphor-icons/react": "^2.1.10",
    "@vitejs/plugin-react": "5.0.4",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "recharts": "^3.9.2",
    "vite": "6.4.2"
  }
}
