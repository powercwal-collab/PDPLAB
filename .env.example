# 本文件用于本地开发；生产配置参考 .env.production.example。
# 仅配置在 Django API 和 Celery Worker 环境，不要放入 VITE_ 前缀变量。
PDP_ENV=development
DJANGO_SECRET_KEY=replace-with-a-strong-random-secret
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
PDP_FRONTEND_URL=http://127.0.0.1:4173/
OPENAI_API_KEY=
PDP_DIAGNOSIS_ADAPTER=auto
PDP_MODEL_NAME=gpt-5.4-mini
PDP_AI_PROTOCOL=responses
OPENAI_BASE_URL=
OPENAI_TIMEOUT_SECONDS=180

# 本地默认使用 SQLite broker；生产请改为 Redis/RabbitMQ。
# CELERY_BROKER_URL=redis://127.0.0.1:6379/0
